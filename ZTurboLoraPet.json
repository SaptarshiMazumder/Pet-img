      "widgets_values": [
        "# --- Anatomy & Limbs ---\ndeformed paws, malformed paws, extra paws, missing paws, fused paws\ndeformed hands, malformed hands, extra fingers, missing fingers, fused fingers\nbad hands, ugly hands, mutated hands, poorly drawn hands\nextra limbs, missing limbs, floating limbs, disconnected limbs\nbad anatomy, wrong anatomy, mutated anatomy\nextra tails, extra ears, extra eyes, extra heads\nasymmetric face, asymmetric ears, lopsided features\n\n# --- Face & Head ---\nugly face, deformed face, distorted face, poorly drawn face\ncross-eyed, wall-eyed, misaligned eyes\nopen mouth showing teeth (unless specified), drooling\nblurry face, low detail face\n\n# --- Quality & Artifacts ---\nblurry, out of focus, soft focus, low resolution, low quality\njpeg artifacts, compression artifacts, pixelated, grainy, noisy\nwatermark, text, signature, logo, stamp, username, caption\nborder, frame, vignette (unless intentional)\noversaturated, washed out, flat lighting\n\n# --- Style Violations ---\nmodern clothing, western clothing, jeans, t-shirts, sneakers\nguns, modern weapons, mechanical objects\ncartoon style, anime style, chibi (unless intentional)\nphotorealistic (for ink wash / ukiyo-e styles)\nCGI, 3D render, digital painting (for traditional styles)\n\n# --- Composition ---\nmultiple animals in frame, crowd, background characters\nduplicate subject, mirror image artifacts\ncluttered composition, busy background that overwhelms subject\n"
      ]
    },
